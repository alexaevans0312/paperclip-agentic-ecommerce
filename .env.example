# Environment example

# Do not put real secrets in this file.
# Copy to .env locally if needed, and keep .env ignored.

PAPERCLIP_ENV=development
PAPERCLIP_APPROVAL_MODE=manual
PAPERCLIP_DEFAULT_SPEND_CAP_USD=25

# Stripe CLI / Projects authentication is handled by Stripe tooling.
# Do not paste Stripe secrets into prompts or committed files.

